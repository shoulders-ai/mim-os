{
  "name": "mim",
  "version": "0.1.0",
  "description": "Workspace kernel for AI-native software building",
  "main": "./out/main/index.js",
  "bin": {
    "mim": "./bin/mim.mjs"
  },
  "type": "module",
  "license": "MIT",
  "author": "Shoulders <contact@shoulde.rs>",
  "repository": {
    "type": "git",
    "url": "https://github.com/shoulders-ai/mim-os.git"
  },
  "homepage": "https://mim.shoulde.rs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "docx-worker:build": "node scripts/build-docx-worker.mjs",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:packages:compat": "MIM_PACKAGE_COMPAT=1 vitest run scripts/package-compat.test.ts",
    "test:watch": "vitest",
    "dist": "electron-vite build && electron-builder --config electron-builder.config.mjs",
    "dist:mac": "electron-vite build && electron-builder --config electron-builder.config.mjs --mac",
    "dist:win": "electron-vite build && electron-builder --config electron-builder.config.mjs --win",
    "dist:linux": "electron-vite build && electron-builder --config electron-builder.config.mjs --linux",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/vue": "^3.0.191",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@floating-ui/vue": "^1.1.11",
    "@headlessui/vue": "^1.7.23",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.3",
    "@mixmark-io/domino": "^2.2.0",
    "@mozilla/readability": "^0.6.0",
    "@tabler/icons-vue": "^3.44.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ag-grid-community": "^35.3.1",
    "ag-grid-vue3": "^35.3.1",
    "ai": "^6.0.191",
    "better-sqlite3": "^11.8.0",
    "chokidar": "^4.0.0",
    "citeproc": "^2.4.63",
    "docx": "^9.7.1",
    "dompurify": "^3.4.9",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "isomorphic-git": "^1.38.3",
    "jszip": "^3.10.1",
    "keytar": "^7.9.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "node-pty": "^1.1.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^6.0.227",
    "pinia": "^3.0.4",
    "sharp": "^0.34.5",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^6.0.0",
    "@xmldom/xmldom": "^0.9.10",
    "electron": "^35.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "vue": "^3.5.0"
  }
}
